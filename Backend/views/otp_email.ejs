<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Your OTP</title>
  </head>
  <body style="font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; color:#333;">
    <div style="max-width:600px;margin:0 auto;padding:24px;border:1px solid #e6e6e6;border-radius:8px;">
      <h2 style="margin:0 0 8px 0;color:#0f172a;">Hiresphere — Password Reset</h2>
      <p style="margin:0 0 16px 0;color:#374151;">Hi <%= name || 'there' %>,</p>
      <p style="margin:0 0 16px 0;color:#374151;">Use the one‑time password (OTP) below to reset your Hiresphere password. The code is valid for 10 minutes.</p>
      <div style="display:flex;align-items:center;justify-content:center;margin:18px 0;padding:12px 16px;background:#f8fafc;border-radius:8px;border:1px dashed #e2e8f0;font-size:22px;font-weight:700;letter-spacing:4px;color:#0ea5e9;">
        <%= otp %>
      </div>
      <p style="margin:0 0 8px 0;color:#6b7280;font-size:13px;">If you didn't request this, ignore this email.</p>
      <p style="margin:16px 0 0 0;color:#6b7280;font-size:13px;">Thanks,<br/>Hiresphere Team</p>
    </div>
  </body>
</html>
